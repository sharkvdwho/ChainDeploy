# =============================================================================
# ChainDeploy — unified environment template (copy to .env and fill in)
# Used by: Docker Compose, FastAPI backend, Next.js frontend (NEXT_PUBLIC_*),
#          GitHub Action, setup_stellar.py / demo_scenario.py / seed_data.py
# =============================================================================

# --- PostgreSQL (docker-compose + DATABASE_URL) ---
POSTGRES_USER=chaindeploy
POSTGRES_PASSWORD=chaindeploy
POSTGRES_DB=chaindeploy
POSTGRES_PORT=5432

# SQLAlchemy async URL for the API (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://chaindeploy:chaindeploy@127.0.0.1:5432/chaindeploy

# --- Service ports (docker-compose) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- FastAPI backend ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://frontend:3000
STELLAR_NETWORK=testnet
DEPLOYMENT_BROADCAST_INTERVAL_SEC=45
SOROBAN_POLL_INTERVAL_SEC=8

# Shared token: GitHub Action chaindeploy_secret + optional CI evaluate auth
# When set, POST /api/deployments/evaluate requires: Authorization: Bearer <CI_WEBHOOK_TOKEN>
CI_WEBHOOK_TOKEN=

# Stellar RPC / Horizon (testnet defaults)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban contract IDs (from scripts/setup_stellar.py or manual deploy)
DEPLOYMENT_DECISION_CONTRACT_ID=
MULTISIG_APPROVAL_CONTRACT_ID=
ROLLBACK_ENGINE_CONTRACT_ID=

# Default deployer secret for evaluate payloads (dev/demo only — never in production)
CHAIN_DEPLOY_DEFAULT_DEPLOYER_SECRET=

# Explicit demo keys (written by setup_stellar.py → .env.chaindemo)
CHAIN_DEPLOY_DEPLOYER_SECRET=
CHAIN_DEPLOY_APPROVER_1_SECRET=
CHAIN_DEPLOY_APPROVER_2_SECRET=
CHAIN_DEPLOY_DEPLOYER_PUBLIC=
CHAIN_DEPLOY_APPROVER_1_PUBLIC=
CHAIN_DEPLOY_APPROVER_2_PUBLIC=

# Dashboard links from API (evaluate response, emails, etc.)
DASHBOARD_BASE_URL=http://localhost:3000

# GET /api/deployments/history response cache (TTL seconds). Set REDIS_URL for shared cache.
DEPLOYMENT_HISTORY_CACHE_TTL_SEC=30
# REDIS_URL=

# Expire stale pending_approval deployments in the DB (minutes).
APPROVAL_PENDING_TIMEOUT_MINUTES=15

# --- GitHub (webhooks + commit statuses) ---
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# --- Next.js (browser — must be reachable from the user’s browser) ---
# Local Docker: use localhost. With ngrok, rebuild frontend after setting public URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_MULTISIG_CONTRACT_ID=
NEXT_PUBLIC_DEPLOYMENT_DECISION_CONTRACT_ID=
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Freighter / signing must match this network (testnet | futurenet | mainnet).
NEXT_PUBLIC_WALLET_NETWORK=testnet

# --- ngrok (docker compose profile: demo-tunnel) ---
NGROK_AUTHTOKEN=
NGROK_UI_PORT=4040

# --- GitHub Action (workflow repo secrets — not loaded by docker; document only) ---
# CHAINDEPLOY_API_URL=https://your-ngrok-url.ngrok-free.app
# CHAIN_DEPLOY_STELLAR_ADDRESS=G...
# CHAIN_DEPLOY_STELLAR_SECRET=S...
# CHAINDEPLOY_API_SECRET=<same as CI_WEBHOOK_TOKEN when protecting evaluate>

# --- Scripts ---
# seed_data.py / demo_scenario.py default API base
CHAINDEPLOY_API_URL=http://127.0.0.1:8000
