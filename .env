# --- PostgreSQL (docker-compose + DATABASE_URL) ---
POSTGRES_USER=chaindeploy
POSTGRES_PASSWORD=chaindeploy
POSTGRES_DB=chaindeploy
POSTGRES_PORT=5433

# SQLAlchemy async URL (asyncpg). Host "postgres" = backend in docker-compose; use 127.0.0.1 if API runs on the host.
DATABASE_URL=postgresql+asyncpg://chaindeploy:chaindeploy@postgres:5432/chaindeploy

# --- Service ports (docker-compose) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- FastAPI backend ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://frontend:3000
STELLAR_NETWORK=testnet
DEPLOYMENT_BROADCAST_INTERVAL_SEC=45
SOROBAN_POLL_INTERVAL_SEC=8

# Shared token: GitHub Action chaindeploy_secret + optional CI evaluate auth
# When set, POST /api/deployments/evaluate requires: Authorization: Bearer <CI_WEBHOOK_TOKEN>
CI_WEBHOOK_TOKEN=Z85zOSUzTqS0QS99qZVFtG-2y_Ut6pqErZdRvH3XMcU

# Stellar RPC / Horizon (testnet defaults)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban contract IDs (from scripts/setup_stellar.py or manual deploy)
DEPLOYMENT_DECISION_CONTRACT_ID=CCXWRBJNYLMWAAYHXXEUZJJ6SBQ4VVNO7T5BH2DSTVDGQG5ARS3CXA4E
MULTISIG_APPROVAL_CONTRACT_ID=CB4BBMQBCD7CLVPHMN7TUJNGE3Z64PSXE4PZ4RK4BRS2DTZNVDL5RXEB
ROLLBACK_ENGINE_CONTRACT_ID=CBNALO2YDG6CKJCO6JZ7IV2L2Y3NF3T4Z6Z7LQWROR67JB35ZF4YCJDO

# Default deployer secret for evaluate payloads (dev/demo only — never in production)
CHAIN_DEPLOY_DEFAULT_DEPLOYER_SECRET=

