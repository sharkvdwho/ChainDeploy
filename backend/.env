# Copy to .env and adjust. Full cross-service template: ../.env.example
# DATABASE_URL must use the asyncpg driver for the API.
DATABASE_URL=postgresql+asyncpg://chaindeploy:chaindeploy@127.0.0.1:5432/chaindeploy

# Comma-separated browser origins allowed for CORS + Socket.IO.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Stellar network label echoed by /health (testnet | futurenet | mainnet).
STELLAR_NETWORK=testnet

# Interval between idle Socket.IO heartbeat broadcasts (seconds).
DEPLOYMENT_BROADCAST_INTERVAL_SEC=45

# Optional shared secret: when set, POST /api/ci/events requires
# Authorization: Bearer <CI_WEBHOOK_TOKEN>
# CI_WEBHOOK_TOKEN=

# Soroban RPC + contract ids (deploy WASM then paste ids here).
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
DEPLOYMENT_DECISION_CONTRACT_ID=
MULTISIG_APPROVAL_CONTRACT_ID=
ROLLBACK_ENGINE_CONTRACT_ID=

# Poll interval for Soroban getEvents (live WebSocket fan-out).
SOROBAN_POLL_INTERVAL_SEC=8

# Deployment history API cache (seconds). Optional Redis for multi-instance sharing.
DEPLOYMENT_HISTORY_CACHE_TTL_SEC=30
# REDIS_URL=redis://127.0.0.1:6379/0

# Auto-expire pending_approval rows after N minutes (DB mirror of approval deadlines).
APPROVAL_PENDING_TIMEOUT_MINUTES=15

# GitHub: webhook HMAC + PAT for commit statuses from ChainDeploy.
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# Default deployer secret for POST /api/deployments/evaluate when not embedded in JSON (dev only).
# CHAIN_DEPLOY_DEFAULT_DEPLOYER_SECRET=
